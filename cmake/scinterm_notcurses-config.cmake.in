@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/scinterm_notcurses-targets.cmake" OPTIONAL)

find_package(PkgConfig REQUIRED)
pkg_check_modules(NOTCURSES REQUIRED notcurses>=3.0.0)

set(SCINTERM_NOTCURSES_LIBRARIES scinterm_notcurses ${NOTCURSES_LIBRARIES})
set(SCINTERM_NOTCURSES_INCLUDE_DIRS "@CMAKE_INSTALL_PREFIX@/include/scinterm" ${NOTCURSES_INCLUDE_DIRS})
